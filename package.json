{
    "name": "note-app-backend",
    "version": "1.0.0",
    "description": "Backend API for Note Application",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ahmetozmtn/note-app-backend.git"
    },
    "keywords": [
        "nodejs",
        "express",
        "api",
        "notes",
        "backend"
    ],
    "author": "ahmetozmtn",
    "license": "MIT",
    "dependencies": {
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^17.2.2",
        "express": "^5.1.0",
        "express-rate-limit": "^8.2.2",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.18.0",
        "nodemailer": "^8.0.5",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "winston": "^3.17.0",
        "winston-mongodb": "^7.0.1",
        "zod": "^4.1.5"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^4.0.16",
        "eslint": "^8.57.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-import": "^2.29.1",
        "mongodb-memory-server": "^11.0.1",
        "nodemon": "^3.1.10",
        "prettier": "^3.2.5",
        "supertest": "^7.1.4",
        "vitest": "^4.0.16"
    }
}
