# Application
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://admin:password123@localhost:27017/noteapp?authSource=admin
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=password123

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h

# Refresh Token Configuration
REFRESH_TOKEN_SECRET_KEY=your-super-secret-refresh-token-key-change-in-production
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_COOKIE_MAX_AGE=604800000

# Cookie Configuration
COOKIE_SAME_SITE=strict

# Email Configuration (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Email Token Configuration
EMAIL_TOKEN_SECRET_KEY=your-email-token-secret-key
EMAIL_TOKEN_EXPIRES_IN=24h

